<configuration name="xml_curl.conf" description="cURL XML Gateway">
  <bindings>
    <binding name="directory">
      <param name="gateway-url" value="http://api:8010/freeswitch/directory" bindings="directory"/>
      <param name="method" value="POST"/>
      <param name="timeout" value="5"/>
    </binding>
    <binding name="dialplan">
      <param name="gateway-url" value="http://api:8010/freeswitch/dialplan" bindings="dialplan"/>
      <param name="method" value="POST"/>
      <param name="timeout" value="5"/>
    </binding>
    <!-- Configuration binding removed: returning not_found for sofia.conf
         prevented FS from using static XML with X-PRE-PROCESS includes.
         Gateways are loaded from /gateways/*.xml files via file includes. -->
  </bindings>
</configuration>
