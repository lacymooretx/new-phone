# === Database ===
NP_DB_HOST=localhost
NP_DB_PORT=5432
NP_DB_NAME=new_phone
NP_DB_ADMIN_USER=new_phone_admin
NP_DB_ADMIN_PASSWORD=change_me_admin
NP_DB_APP_USER=new_phone_app
NP_DB_APP_PASSWORD=change_me_app

# === Redis ===
NP_REDIS_URL=redis://localhost:6379/0

# === JWT ===
NP_JWT_SECRET_KEY=change-me-to-a-random-64-char-string
NP_JWT_ALGORITHM=HS256
NP_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
NP_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === FreeSWITCH ===
NP_FREESWITCH_HOST=localhost
NP_FREESWITCH_ESL_PORT=8021
NP_FREESWITCH_ESL_PASSWORD=ClueCon
NP_FREESWITCH_WSS_PORT=7443
NP_FREESWITCH_WSS_HOST=localhost

# === API ===
NP_API_HOST=0.0.0.0
NP_API_PORT=8000
NP_DEBUG=false
NP_LOG_LEVEL=INFO
NP_CORS_ALLOWED_ORIGINS=http://localhost:3000
NP_RATE_LIMIT_DEFAULT=100/minute
NP_RATE_LIMIT_AUTH=10/minute
NP_METRICS_TOKEN=
NP_MAX_FAILED_LOGIN_ATTEMPTS=5
NP_LOCKOUT_DURATION_MINUTES=15

# === SSO ===
NP_SSO_CALLBACK_URL=http://localhost:8000/api/v1/auth/sso/callback
NP_SSO_FRONTEND_URL=http://localhost:3000

# === MFA ===
NP_MFA_ISSUER=NewPhone

# === Phone Provisioning ===
NP_PROVISIONING_SIP_SERVER=pbx.example.com
NP_PROVISIONING_NTP_SERVER=pool.ntp.org
NP_PROVISIONING_TIMEZONE=America/New_York

# === MinIO (Object Storage) ===
NP_MINIO_ENDPOINT=localhost:9000
NP_MINIO_ACCESS_KEY=minioadmin
NP_MINIO_SECRET_KEY=minioadmin
NP_MINIO_BUCKET=recordings
NP_MINIO_SECURE=false
NP_MINIO_ARCHIVE_BUCKET=recordings-archive

# === SMTP (Voicemail-to-Email) ===
NP_SMTP_HOST=localhost
NP_SMTP_PORT=1025
NP_SMTP_USER=
NP_SMTP_PASSWORD=
NP_SMTP_FROM_ADDRESS=voicemail@newphone.local
NP_SMTP_ATTACH_AUDIO=true

# === AI Voice Agent Engine ===
NP_AI_WS_HOST_PORT=8090
NP_AI_API_HOST_PORT=8091
NP_AI_ENGINE_URL=http://localhost:8091

# === Telephony Providers ===
# ClearlyIP: location keycode from ClearlyIP portal (optional — can be stored in DB instead)
# NP_CLEARLYIP_KEYCODE=
# Twilio: account credentials (optional — can be stored in DB instead)
# NP_TWILIO_ACCOUNT_SID=
# NP_TWILIO_AUTH_TOKEN=

# === Encryption ===
NP_TRUNK_ENCRYPTION_KEY=change-me-generate-with-fernet
