<?xml version="1.0" encoding="UTF-8"?>
<!-- Sangoma P-Series Auto-Provisioned Configuration -->
<!-- Device: {{ device.name or device.mac_address }} -->
<!-- Model: {{ phone_model.manufacturer }} {{ phone_model.model_name }} -->
<!-- Tenant: {{ tenant.name }} -->
<!-- Generated by New Phone Platform -->
<PhoneConfig>
  <MAC>{{ device.mac_address }}</MAC>

{% if extension %}
  <Account>
    <AccountIndex>1</AccountIndex>
    <Enable>1</Enable>
    <Label>{{ extension.extension_number }}</Label>
    <DisplayName>{{ extension.internal_cid_name or extension.extension_number }}</DisplayName>
    <AuthName>{{ extension.sip_username }}</AuthName>
    <AuthPassword>{{ sip_password }}</AuthPassword>
    <UserName>{{ extension.sip_username }}</UserName>
    <SIPServer>{{ sip_server }}</SIPServer>
    <SIPPort>5061</SIPPort>
    <Transport>TLS</Transport>
    <TLSEnabled>1</TLSEnabled>
    <SRTPMode>2</SRTPMode>
    <RegisterExpires>3600</RegisterExpires>
    <SubscribeMWI>1</SubscribeMWI>
{% if extension.voicemail_box_id %}
    <VoicemailExtension>*97</VoicemailExtension>
{% endif %}
  </Account>
{% else %}
  <Account>
    <AccountIndex>1</AccountIndex>
    <Enable>0</Enable>
  </Account>
{% endif %}

  <Network>
    <DHCPEnabled>1</DHCPEnabled>
    <LLDPEnabled>1</LLDPEnabled>
  </Network>

  <Time>
    <NTPServer>{{ ntp_server }}</NTPServer>
    <Timezone>{{ timezone }}</Timezone>
    <UseDHCPTime>0</UseDHCPTime>
  </Time>

  <Features>
    <DirectMedia>0</DirectMedia>
    <CallWaiting>1</CallWaiting>
    <DoNotDisturb>0</DoNotDisturb>
    <PowerSaving>0</PowerSaving>
  </Features>
</PhoneConfig>
