#!version:1.0.0.1
## Yealink Auto-Provisioned Configuration
## Device: {{ device.name or device.mac_address }}
## Model: {{ phone_model.manufacturer }} {{ phone_model.model_name }}
## Tenant: {{ tenant.name }}
## Generated by New Phone Platform

###
### Account Settings
###
{% if extension %}
account.1.enable = 1
account.1.label = {{ extension.extension_number }}
account.1.display_name = {{ extension.internal_cid_name or extension.extension_number }}
account.1.auth_name = {{ extension.sip_username }}
account.1.user_name = {{ extension.sip_username }}
account.1.password = {{ sip_password }}
account.1.sip_server.1.address = {{ sip_server }}
account.1.sip_server.1.port = 5061
account.1.sip_server.1.transport_type = 2
account.1.sip_server.1.expires = 3600
account.1.nat.udp_update_enable = 1
account.1.nat.udp_update_time = 30
account.1.subscribe_mwi = 1
{% if extension.voicemail_box_id %}
voice_mail.number.1 = *97
{% endif %}
{% else %}
account.1.enable = 0
{% endif %}

###
### Network Settings
###
network.dhcp_enable = 1
network.lldp.enable = 1

###
### NTP / Time
###
local_time.ntp_server1 = {{ ntp_server }}
local_time.time_zone_name = {{ timezone }}
local_time.dhcp_time = 0

###
### Phone Settings
###
phone_setting.ring_type = Ring1.wav
phone_setting.backlight_time = 60
features.direct_ip_call_enable = 0
features.power_saving.enable = 0

###
### Security
###
security.trust_certificates = 1
account.1.srtp_encryption = 2
static.security.user_password.server = admin
